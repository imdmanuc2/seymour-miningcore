#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "${ROOT_DIR}/lib/common.sh"
source "${ROOT_DIR}/lib/pool_repo.sh"
source "${ROOT_DIR}/lib/status.sh"
source "${ROOT_DIR}/lib/health.sh"
source "${ROOT_DIR}/lib/deps.sh"
source "${ROOT_DIR}/lib/install.sh"
source "${ROOT_DIR}/lib/pool.sh"

cmd="${1:-help}"
subcmd="${2:-}"

show_help() {
  cat <<'HELP'
Seymour MiningCore CLI

Usage:
  smc version
  smc status
  smc health
  smc deps
  smc license
  smc install-plan
  smc pools
  smc pool-template
  smc pool-validate <pool.json>

Preferred Pool Commands:
  smc pool list
  smc pool template
  smc pool validate <pool.json>

Future:
  smc install
  smc pool create
  smc pool remove
  smc pool enable
  smc pool disable
  smc node test
  smc backup
  smc restore
  smc update
  smc diagnostics
HELP
}

case "$cmd" in
  version)
    echo "${SMC_PRODUCT} ${SMC_VERSION}"
    ;;

  status)
    smc_status
    ;;

  health)
    smc_health
    ;;

  deps|dependencies)
    smc_deps
    ;;

  install-plan)
    smc_install_plan
    ;;

  pools|pool-list)
    smc_pool_list
    ;;

  pool-template)
    smc_pool_template
    ;;

  pool-validate)
    smc_pool_validate "${2:-}"
    ;;

  pool)
    case "$subcmd" in
      list)
        smc_pool_list
        ;;
      template)
        smc_pool_template
        ;;
      validate)
        smc_pool_validate "${3:-}"
        ;;
      create)
        smc_pool_create "${@:3}"
        ;;
      enable)
        smc_pool_set_enabled "${3:-}" true
        ;;
      disable)
        smc_pool_set_enabled "${3:-}" false
        ;;
      remove)
        smc_pool_remove "${3:-}"
        ;;
      restore)
        smc_pool_restore "${3:-}"
        ;;
      *)
        echo "Unknown pool command: ${subcmd}" >&2
        echo "Run: smc help" >&2
        exit 1
        ;;
    esac
    ;;

  license)
    cat <<JSON
{
  "product": "${SMC_PRODUCT}",
  "developerFee": {
    "required": true,
    "percent": ${SMC_FEE_PERCENT},
    "status": "active"
  },
  "license": {
    "status": "draft",
    "type": "commercial-open-source",
    "tamperStatus": "unknown"
  }
}
JSON
    ;;

  help|--help|-h)
    show_help
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    echo "Run: smc help" >&2
    exit 1
    ;;
esac
