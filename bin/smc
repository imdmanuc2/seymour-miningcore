#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "${ROOT_DIR}/lib/common.sh"
source "${ROOT_DIR}/lib/pool_repo.sh"
source "${ROOT_DIR}/lib/graph.sh"
source "${ROOT_DIR}/lib/status.sh"
source "${ROOT_DIR}/lib/health.sh"
source "${ROOT_DIR}/lib/deps.sh"
source "${ROOT_DIR}/lib/install.sh"
source "${ROOT_DIR}/lib/service.sh"
source "${ROOT_DIR}/lib/token.sh"
source "${ROOT_DIR}/lib/license.sh"
source "${ROOT_DIR}/lib/identity.sh"
source "${ROOT_DIR}/lib/pool.sh"
source "${ROOT_DIR}/lib/doctor.sh"
source "${ROOT_DIR}/lib/install_engine.sh"

cmd="${1:-help}"
subcmd="${2:-}"

show_help() {
  cat <<'HELP'
Seymour MiningCore CLI

System:
  smc version
  smc status
  smc health
  smc doctor

Diagnostics:
  smc deps
  smc install-plan
  smc graph

Pools:
  smc pool list
  smc pool template
  smc pool validate <pool.json>
  smc pool create
  smc pool enable <poolId>
  smc pool disable <poolId>
  smc pool remove <poolId>
  smc pool restore <poolId>

Services:
  smc service status [service]
  smc service restart <service>

Security:
  smc token status
  smc token create
  smc token show
  smc token rotate

Licensing:
  smc license status
  smc license show

Legacy Compatibility:
  smc pools
  smc pool-template
  smc pool-validate <pool.json>

Coming Soon:
  smc install
  smc node test
  smc backup
  smc restore
  smc update
  smc diagnostics
HELP
}

case "$cmd" in
  version)
    echo "${SMC_PRODUCT} ${SMC_VERSION}"
    ;;

  status)
    smc_status
    ;;

  graph)
    smc_graph
    ;;

  health)
    smc_health
    ;;

  doctor)
    smc_doctor
    ;;

  deps|dependencies)
    smc_deps
    ;;

  install-plan)
    smc_install_plan
    ;;

  install)
    smc_install_engine_run "${2:-run}"
    ;;

  pools|pool-list)
    smc_pool_list
    ;;

  pool-template)
    smc_pool_template
    ;;

  pool-validate)
    smc_pool_validate "${2:-}"
    ;;

  pool)
    case "$subcmd" in
      list)
        smc_pool_list
        ;;
      template)
        smc_pool_template
        ;;
      validate)
        smc_pool_validate "${3:-}"
        ;;
      create)
        smc_pool_create "${@:3}"
        ;;
      enable)
        smc_pool_set_enabled "${3:-}" true
        ;;
      disable)
        smc_pool_set_enabled "${3:-}" false
        ;;
      remove)
        smc_pool_remove "${3:-}"
        ;;
      restore)
        smc_pool_restore "${3:-}"
        ;;
      *)
        echo "Unknown pool command: ${subcmd}" >&2
        echo "Run: smc help" >&2
        exit 1
        ;;
    esac
    ;;

  service)
    smc_service_action "${2:-status}" "${3:-${MININGCORE_SERVICE}}"
    ;;

  token)
    smc_token_command "${2:-status}"
    ;;

  license)
    smc_license_command "${2:-status}"
    ;;

  identity)
    smc_identity_command "${2:-status}"
    ;;

  help|--help|-h)
    show_help
    ;;

  *)
    echo "Unknown command: $cmd" >&2
    echo "Run: smc help" >&2
    exit 1
    ;;
esac
